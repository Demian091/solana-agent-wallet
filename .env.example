# Solana Network Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed

# Agent Configuration
AGENT_NAME=trading-agent-01
MAX_TRANSACTION_AMOUNT_SOL=1.0
ALLOWED_TOKENS=SOL,USDC
RISK_LEVEL=low

# Security
ENCRYPTION_KEY=your-secure-encryption-key-min-32-chars
POLICY_VALIDATION_ENABLED=true
MAX_DAILY_TRANSACTIONS=100

# Optional: Turnkey Integration (for production)
TURNKEY_API_PRIVATE_KEY=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_ORGANIZATION_ID=

# Logging
LOG_LEVEL=info
LOG_FILE=logs/agent.log